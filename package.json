{
  "name": "sambungin",
  "version": "0.1.0",
  "description": "Sambungin — local OpenAI-compatible router for CodeBuddy.ai with auto key rotation, plus a signup bot for Unlucid.ai + CodeBuddy.ai (Camoufox + proxies). One dashboard for everything.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "sambungin": "concurrently --names \"api,dashboard\" --prefix-colors \"cyan,magenta\" \"node server/index.js\" \"npm run dev --prefix dashboard\"",
    "dev": "concurrently --names \"api,dashboard\" --prefix-colors \"cyan,magenta\" \"node server/index.js\" \"npm run dev --prefix dashboard\"",
    "server": "node server/index.js",
    "dashboard": "npm run dev --prefix dashboard",
    "build:dashboard": "npm run build --prefix dashboard"
  },
  "bin": {
    "sambungin": "./bin/sambungin.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "camoufox-js": "^0.10.2",
    "chalk": "^5.6.2",
    "chokidar": "^3.6.0",
    "express": "^4.21.1",
    "imapflow": "^1.3.3",
    "playwright-core": "^1.59.1",
    "readline-sync": "^1.4.10"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
